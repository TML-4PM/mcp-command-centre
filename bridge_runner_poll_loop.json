{
  "name": "bridge_runner_poll_loop",
  "version": "2.0",
  "mode": "poll",
  "fix_log": "2026-04-14: corrected watch paths from telegram to control_tower_eventbridge_autofix",
  "source": {
    "provider": "github",
    "repository": "TML-4PM/mcp-command-centre",
    "branch": "main"
  },
  "schedule": {
    "type": "interval_seconds",
    "value": 30
  },
  "watch": {
    "paths": [
      "bridge_runner/control_tower_eventbridge_autofix/ACTIVE_PAYLOAD.json",
      "bridge_runner/control_tower_eventbridge_autofix/RUNTIME_GUARD.json",
      "bridge_runner/inbox/",
      "bridge_runner/trigger.json"
    ]
  },
  "dedupe": {
    "strategy": "commit_sha",
    "state_key": "bridge_runner:last_processed_sha:control_tower"
  },
  "actions": [
    {"step": "fetch_latest_commit", "required": true},
    {"step": "compare_with_last_processed_sha", "required": true},
    {"step": "pull_repo_if_changed", "required": true},
    {"step": "validate_against_runtime_guard", "required": true, "guard_path": "bridge_runner/control_tower_eventbridge_autofix/RUNTIME_GUARD.json"},
    {"step": "load_active_payload", "required": true, "payload_path": "bridge_runner/control_tower_eventbridge_autofix/ACTIVE_PAYLOAD.json"},
    {"step": "invoke_bridge_lambda", "required": true},
    {"step": "write_execution_log", "required": true, "table": "bridge_runner_execution_log"},
    {"step": "mark_processed_sha", "required": true}
  ]
}
